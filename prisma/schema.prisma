// MacroLens — AI-powered diet & macro tracker
// Docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

/// A meal slot in the user's day — "Breakfast", "Tea time", "Bed time", whatever they call it.
///
/// This used to be a four-value enum, which meant the app decided how you eat. It doesn't:
/// people have pre-workout, post-workout, chai, a midnight snack. Every user gets the usual
/// four seeded, and can rename, reorder, add and remove from there.
model MealSlot {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  name   String
  /// Display order, not a time of day — "tea" happens at wildly different hours for different
  /// people, and sorting by a clock would fight the user rather than help them.
  order  Int

  entries FoodEntry[]

  @@unique([userId, name])
  @@index([userId, order])
}

/// Where a food's nutrition numbers came from. Drives the "estimated" badge in the UI.
enum NutritionSource {
  USDA // FoodData Central — measured lab values
  OFF // Open Food Facts — the manufacturer's own label, via barcode
  AI // LLM estimate — approximate, shown with a warning
  MANUAL // User typed the numbers in themselves
}

/// A meal photo. Stored as bytes in Postgres rather than object storage: a downscaled plate
/// photo is ~80KB, this app is single-digit users, and it keeps deploys to "set DATABASE_URL"
/// with no bucket to provision. Swap to Vercel Blob (put the URL in FoodEntry.photoUrl, which
/// already exists) if you ever outgrow that — nothing else has to change.
model Photo {
  id        String      @id @default(cuid())
  userId    String
  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  mediaType String
  bytes     Bytes
  createdAt DateTime    @default(now())
  entries   FoodEntry[]

  @@index([userId])
}

/// Identity lives here, in your own database — there is no third-party account to lose.
/// `email` IS the identity; a user who changes their address gets a new row, which for a
/// personal food log is the correct behaviour.
model User {
  id            String    @id @default(cuid())
  email         String    @unique
  /// Set the first time an emailed OTP is verified. Null means the address is unproven.
  emailVerified DateTime?
  name          String?
  image         String?
  createdAt     DateTime  @default(now())

  /// scrypt, salted, in the format produced by lib/password.ts. Null for an account that has
  /// verified its email but not yet chosen a password.
  passwordHash String?

  /// Bumped to invalidate every existing session at once.
  ///
  /// Password auth forces JWT sessions (Auth.js can't persist credential logins to the Session
  /// table), and a JWT cannot be revoked — signing out only drops the local cookie, so a copied
  /// token stays valid until it expires. Every request already loads this row, so comparing
  /// this counter against the one baked into the token costs nothing and hands revocation back.
  /// Changing your password bumps it, which signs out every other device.
  tokenVersion Int @default(0)

  accounts Account[]
  sessions Session[]

  goal    Goal?
  meals   MealSlot[]
  entries FoodEntry[]
  photos  Photo[]
}

/// Auth.js requires these three even for magic-link-only auth. `Account` stays empty unless
/// you add an OAuth provider later; `Session` is the live login; `VerificationToken` is the
/// one-time magic link, deleted the moment it's used.
model Account {
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([provider, providerAccountId])
}

model Session {
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@id([identifier, token])
}

/// A one-time code emailed to prove you own an address — used to set a password the first time,
/// and to reset a forgotten one. It is NOT a login: verifying a code only earns you the right
/// to set a password, never a session. That keeps the six digits from being a second, weaker
/// credential that never expires.
model EmailOtp {
  /// One live code per address. Requesting a new one replaces the old, so an old email in the
  /// inbox stops working the moment you ask for another.
  email String @id

  /// Hashed, never stored raw. A leaked database must not hand out working login codes.
  codeHash String
  expires  DateTime

  /// Brute-forcing 6 digits is a million guesses; this makes it five.
  attempts Int @default(0)

  /// Throttles resends — one code per minute per address.
  createdAt DateTime @default(now())
}

/// Daily targets. Micros are deliberately not goal-tracked — dial in macros first.
model Goal {
  id      String @id @default(cuid())
  userId  String @unique
  user    User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  kcal    Int    @default(2500)
  protein Int    @default(150)
  carbs   Int    @default(280)
  fat     Int    @default(70)
  fiber   Int    @default(30)
}

/// One food eaten at one meal on one day. Nutrition is denormalised (copied in at
/// log time) so that editing a FoodCache row never rewrites history.
model FoodEntry {
  id     String   @id @default(cuid())
  userId String
  user   User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  /// Local calendar day. A DATE column (not timestamp) so a meal logged at 11pm IST
  /// never drifts into the previous day via UTC conversion.
  date   DateTime @db.Date
  /// Restrict, not Cascade: deleting a meal slot must never silently delete the food you ate
  /// in it. The API refuses to remove a slot that still has entries and says how many.
  mealId String
  meal   MealSlot @relation(fields: [mealId], references: [id], onDelete: Restrict)

  name     String
  /// What the user sees: quantity + unit, e.g. 2 × "roti".
  quantity Float  @default(1)
  unit     String @default("serving")
  /// What the maths uses. Every nutrition field below is the total for this many grams.
  grams    Float

  kcal    Float
  protein Float
  carbs   Float
  fat     Float
  fiber   Float @default(0)
  sugar   Float @default(0)
  /// Micronutrients as { key: { amount, unit } }, e.g. { iron: { amount: 2.1, unit: "mg" } }.
  /// JSON rather than columns because coverage varies wildly by food and data source.
  micros  Json?

  source     NutritionSource
  /// AI portion-estimate confidence: "high" | "medium" | "low". Null for non-AI sources.
  confidence String?
  /// The photo this entry was read off, if any. Several entries share one photo — a thali
  /// yields six rows from one picture. SetNull so deleting a photo doesn't delete the food.
  photoId    String?
  photo      Photo?  @relation(fields: [photoId], references: [id], onDelete: SetNull)
  /// For a future move to object storage; unused while photos live in the Photo table.
  photoUrl   String?
  /// EAN/UPC, when the entry came from a barcode scan.
  barcode    String?

  createdAt DateTime @default(now())

  @@index([userId, date])
}

/// Nutrition per 100g, keyed by normalised food name. Every resolved food lands here,
/// so the second "2 roti" of the week costs a DB hit instead of a USDA + LLM round-trip.
model FoodCache {
  id          String          @id @default(cuid())
  /// Lowercased, singularised, whitespace-collapsed name. See normaliseFoodKey().
  key         String          @unique
  displayName String
  source      NutritionSource

  kcal    Float
  protein Float
  carbs   Float
  fat     Float
  fiber   Float @default(0)
  sugar   Float @default(0)
  micros  Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
